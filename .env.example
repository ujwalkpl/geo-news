# Mapbox — get a free token at https://mapbox.com
VITE_MAPBOX_TOKEN=

# API base URL (used by the frontend)
VITE_API_URL=http://localhost:8080

# Postgres
POSTGRES_URL=postgresql://geonews:geonews_secret@localhost:5433/geonews

# Redis
REDIS_URL=redis://localhost:6379

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200

# Mapbox geocoding (used by classifier service)
MAPBOX_TOKEN=

# Google Cloud Storage (used by upload service)
GCS_BUCKET=

# Gemini API (used by summarizer service)
GEMINI_API_KEY=

# JWT
JWT_SECRET=change-me-in-production
